# Neon PostgreSQL (production)
DATABASE_URL="postgresql://user:pass@ep-something-pooler.us-east-1.aws.neon.tech/neondb?channel_binding=require&connect_timeout=15&sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-something.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Admin token for auth.
# ADMIN_TOKEN is the server-side secret that the API middleware validates.
# It MUST be set to a strong, random value in production; if it is unset the
# API is denied (fails closed) in production.
ADMIN_TOKEN="change-me-in-production"
# WARNING: NEXT_PUBLIC_* variables are inlined into the client JS bundle and
# are therefore visible to anyone who loads the app. This value is sent by the
# browser as the x-admin-token header and must equal ADMIN_TOKEN for requests
# to succeed. Because it is public, it is NOT a real security boundary — treat
# the current setup as a soft guard and migrate to a proper auth flow
# (e.g. next-auth, already a dependency) for genuine access control.
NEXT_PUBLIC_ADMIN_TOKEN="change-me-in-production"
